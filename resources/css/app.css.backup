}

html[data-theme='dark'] .app-brand-fallback {
    background: linear-gradient(135deg, #0ea5e9 0%, #1d4ed8 100%) !important;
    box-shadow: 0 18px 30px -24px rgba(14, 165, 233, 0.6);
}

