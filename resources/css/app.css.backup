}

.user-profile-device-card {
    @apply rounded-[1.4rem] border border-slate-200 bg-slate-50/90 px-4 py-4 transition hover:border-sky-200 hover:bg-sky-50/70;
}

.user-profile-device-title {
    @apply text-sm font-semibold text-slate-900;
}

.user-profile-device-meta {
    @apply mt-2 text-xs leading-5 text-slate-500;
}

.user-profile-device-sub {
    @apply mt-1 text-xs leading-5 text-slate-400;
}

.user-profile-request-group {
    @apply rounded-[1.4rem] border border-slate-200 bg-slate-50/70 p-4;
}

.user-profile-request-head {
    @apply flex items-center justify-between gap-3 text-sm font-semibold text-slate-900;
}

.user-profile-request-head a {
    @apply text-xs font-semibold uppercase tracking-[0.14em] text-sky-700 transition hover:text-sky-800;
}

.user-profile-request-item {
    @apply mt-3 rounded-2xl border border-slate-200 bg-white px-4 py-3;
}

.user-profile-request-item-incoming {
    @apply border-sky-200 bg-sky-50/60;
}

.user-profile-request-title {
    @apply flex items-center gap-2 text-sm font-semibold text-slate-900;
}

.user-profile-request-meta {
    @apply mt-1 text-xs leading-5 text-slate-500;
}

.user-profile-request-copy {
    @apply mt-2 text-sm leading-6 text-slate-600;
}

.user-profile-audit-item {
    @apply rounded-[1.4rem] border border-slate-200 bg-slate-50/80 px-4 py-4;
}

.user-profile-audit-title {
    @apply text-sm font-semibold text-slate-900;
}

.user-profile-audit-copy {
    @apply mt-2 text-sm leading-6 text-slate-600;
}

.user-profile-audit-meta {
    @apply mt-2 text-xs leading-5 text-slate-500;
}

.user-profile-history-item {
    @apply rounded-[1.4rem] border border-slate-200 bg-slate-50/80 px-4 py-4;
}

.user-profile-history-head {
    @apply flex flex-wrap items-start justify-between gap-3;
}

.user-profile-history-title {
    @apply text-sm font-semibold text-slate-900;
}

.user-profile-history-meta {
    @apply mt-2 flex flex-wrap items-center gap-2 text-xs leading-5 text-slate-500;
}

.user-profile-history-copy {
    @apply mt-2 text-sm leading-6 text-slate-600;
}

.request-card-grid {
    @apply mt-4 grid gap-4 xl:grid-cols-[1.05fr_0.95fr];
}

.request-info-panel {
    @apply rounded-[1.5rem] border border-slate-200 bg-slate-50/90 p-5;
}

.request-device-panel {
    @apply rounded-[1.5rem] border border-slate-200 bg-white p-5 shadow-sm;
}

.request-panel-heading {
    @apply inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.18em] text-slate-500;
}

.request-panel-heading-icon {
    @apply inline-flex h-8 w-8 items-center justify-center rounded-2xl bg-white text-slate-600 ring-1 ring-slate-200;
}

.request-field-grid {
    @apply mt-4 grid gap-3 md:grid-cols-2;
}

.request-field-card {
    @apply rounded-2xl bg-white px-4 py-3 ring-1 ring-slate-200/80;
}

.request-field-card-wide {
    @apply md:col-span-2;
}

.request-field-label {
    @apply inline-flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-400;
}

.request-field-value {
    @apply mt-2 text-sm leading-6 text-slate-700;
}

.request-device-hero {
    @apply flex items-start gap-4;
}

.request-device-thumb {
    @apply h-12 w-12 rounded-[1rem] object-cover ring-1 ring-slate-200;
}

.request-device-thumb-placeholder {
    @apply flex items-center justify-center bg-slate-100 text-slate-400;
}

.request-device-chip {
    @apply inline-flex items-center gap-2 rounded-full bg-slate-100 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.14em] text-slate-600 ring-1 ring-slate-200;
}

.request-device-meta-grid {
    @apply mt-4 grid gap-3 md:grid-cols-2;
}

.request-description-box {
    @apply mt-2 rounded-2xl bg-white px-4 py-3 text-sm leading-6 text-slate-700 ring-1 ring-slate-200;
}

.request-notification-target:target {
    @apply ring-2 ring-sky-300 shadow-[0_22px_60px_-38px_rgba(14,165,233,0.5)];
}

.surface-toolbar + .filter-summary,
.filter-summary + .device-table-shell,
.filter-summary + .app-table-shell,
.filter-summary + .overflow-x-auto,
.filter-summary + .overflow-hidden,
.devices-filter-surface + .app-table-shell,
.devices-filter-surface + .device-table-shell,
.surface-toolbar + .overflow-x-auto,
.surface-toolbar + .overflow-hidden,
.surface-toolbar + .device-table-shell,
.surface-toolbar + .app-table-shell {
    @apply mt-3;
}

/* Devices index - new filter and search design */
.devices-filter-surface {
    @apply rounded-[1.5rem] border border-slate-200 bg-white px-3 py-2.5 shadow-sm mb-4 transition duration-200;
}

.devices-filter-surface-elevated {
    @apply space-y-0.5 shadow-[0_26px_60px_-45px_rgba(15,23,42,0.22)];
}

.devices-filter-surface-elevated:hover {
    box-shadow: 0 28px 70px -48px rgba(15, 23, 42, 0.28);
}

.devices-filter-header {
    @apply mb-0 flex flex-col gap-4 lg:flex-row lg:items-start;
}

.devices-filter-section {
    @apply space-y-2 rounded-[1.25rem] border border-slate-200/80 bg-slate-50/50 p-2.5 lg:flex-1;
}

.devices-filter-title {
    @apply flex items-center gap-1.5 text-xs font-bold uppercase tracking-[0.16em] text-slate-500;
}

.devices-filter-grid {
    @apply grid grid-cols-1 gap-2.5;
}

.devices-filters-grid {
    @apply grid grid-cols-1 gap-2 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 2xl:grid-cols-6;
}

.toolbar-panels {
    @apply grid grid-cols-1 gap-3 xl:grid-cols-[minmax(16rem,0.8fr)_minmax(0,2.2fr)];
}

.toolbar-panels-wide {
    @apply xl:grid-cols-[minmax(16rem,0.76fr)_minmax(0,2.24fr)];
}

.request-toolbar-filters-grid {
    @apply grid grid-cols-1 gap-2 md:grid-cols-2 xl:grid-cols-4 2xl:grid-cols-5;
}

.request-toolbar-filters-grid-admin {
    @apply 2xl:grid-cols-5;
}

.transfer-search-grid {
    @apply grid grid-cols-1 gap-2 xl:grid-cols-[minmax(0,0.9fr)_minmax(0,1.35fr)];
}

.transfer-toolbar-filters-grid {
    @apply grid grid-cols-1 gap-2 md:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-5;
}

.transfer-toolbar-filters-grid-admin {
    @apply 2xl:grid-cols-6;
}

.transfer-filters-grid {
    @apply grid grid-cols-1 gap-2 md:grid-cols-2 xl:grid-cols-4;
}

.transfer-filters-grid-admin {
    @apply 2xl:grid-cols-5;
}

.transfer-toolbar-main {
    @apply grid grid-cols-1 gap-2 md:grid-cols-2 2xl:grid-cols-[minmax(0,1.05fr)_minmax(0,1.1fr)_minmax(0,1fr)_minmax(0,1fr)_minmax(0,0.76fr)_minmax(0,0.76fr)];
}

.transfer-toolbar-main-admin {
    @apply xl:grid-cols-[minmax(0,1.05fr)_minmax(0,1.1fr)_minmax(0,1fr)_minmax(0,1fr)_minmax(0,1fr)_minmax(0,0.76fr)_minmax(0,0.76fr)];
}

.devices-search-group {
    @apply grid grid-cols-[minmax(0,1fr)_auto] gap-2 md:items-end;
}

.devices-search-label {
    @apply flex flex-col gap-1;
}

.devices-search-label span {
    @apply text-xs font-medium text-slate-600;
}

.devices-code-input {
    @apply w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-900 shadow-sm transition focus:border-sky-500 focus:outline-none focus:ring-2 focus:ring-sky-200;
}

.devices-text-search {
    @apply flex flex-col gap-0.5;
}

.devices-text-search span {
    @apply text-xs font-medium text-slate-600;
}

.transfer-search-grid .devices-text-search .crud-control,
.transfer-filters-grid .crud-control,
.transfer-filters-grid .searchable-select-trigger {
    min-height: 2.75rem;
}

.transfer-toolbar-main .crud-control,
.transfer-toolbar-main .searchable-select-trigger,
.transfer-toolbar-main .localized-date-trigger {
    min-height: 2.75rem;
}

.transfer-toolbar-main .devices-search-group {
    gap: 0.625rem;
}

.devices-filter-divider {
    @apply my-2 h-px bg-gradient-to-r from-transparent via-slate-200 to-transparent;
}

.repairs-toolbar-filters-grid {
    @apply grid grid-cols-1 gap-2 md:grid-cols-2 xl:grid-cols-5;
}

.audit-toolbar-filters-grid {
    @apply grid grid-cols-1 gap-2 md:grid-cols-2 xl:grid-cols-5;
}

@media (min-width: 1280px) {
    .devices-index-page > form.devices-filter-surface {
        display: grid;
        grid-template-columns: minmax(18rem, 0.92fr) minmax(0, 3.08fr);
        align-items: start;
        gap: 0.75rem;
    }

    .devices-index-page > form.devices-filter-surface .devices-filter-header {
        min-width: 0;
    }

    .devices-index-page > form.devices-filter-surface .devices-filter-divider {
        display: none;
    }

    .devices-index-page > form.devices-filter-surface .devices-filter-grid {
        grid-template-columns: minmax(0, 1fr);
        gap: 0.625rem;
    }

    .devices-index-page > form.devices-filter-surface .devices-filters-grid {
        grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr) minmax(0, 0.72fr) minmax(0, 1.15fr) minmax(0, 1fr);
        gap: 0.625rem;
    }

    .devices-index-page > form.devices-filter-surface .devices-filter-section {
        height: 100%;
    }

    .devices-index-page > form.devices-filter-surface .devices-search-group {
        gap: 0.625rem;
    }

    .devices-index-page > form.devices-filter-surface .devices-code-search-btn {
        white-space: nowrap;
    }

    .devices-index-page > form.devices-filter-surface .filter-toolbar-footer {
        grid-column: 1 / -1;
    }
}

/* Device search highlight animation */
@keyframes device-highlight-pulse {
    0%, 100% {
        box-shadow: 0 0 0 0 rgba(14, 165, 233, 0.7);
        background-color: rgba(14, 165, 233, 0.15);
    }
    50% {
        box-shadow: 0 0 0 8px rgba(14, 165, 233, 0);
        background-color: rgba(14, 165, 233, 0.05);
    }
}

.toolbar-actions {
    @apply flex flex-wrap items-center gap-3 md:justify-end;
}

.status-segmented-control {
    @apply inline-flex w-full items-center gap-2 rounded-[1.25rem] border border-slate-200 bg-slate-50 p-1.5;
}

.status-segment {
    @apply inline-flex min-w-0 flex-1 items-center justify-center gap-2 rounded-[1rem] px-3 py-2 text-sm font-semibold text-slate-600 transition;
}

.status-segment:hover {
    @apply bg-white text-slate-900;
}

.status-segment-active {
    @apply bg-white shadow-sm ring-1 ring-slate-200;
}

.status-segment-emerald.status-segment-active {
    @apply text-emerald-700 ring-emerald-200;
}

.status-segment-slate.status-segment-active {
    @apply text-slate-800 ring-slate-300;
}

.status-segment-rose.status-segment-active {
    @apply text-rose-700 ring-rose-200;
}

.role-toggle {
    @apply inline-flex w-full items-center gap-3 rounded-[1.25rem] border border-slate-200 bg-slate-50 p-2 transition-all duration-200;
}

.role-toggle:hover {
    @apply border-slate-300 bg-slate-100;
}

.role-toggle-btn {
    @apply inline-flex flex-1 items-center justify-center gap-2 rounded-[1rem] px-4 py-2.5 text-sm font-semibold text-slate-600 transition-all duration-300 ease-in-out;
}

.role-toggle-btn:hover:not(.role-toggle-active) {
    @apply bg-white/60 text-slate-900;
}

.role-toggle-active {
    @apply bg-white text-slate-900 shadow-md ring-1 ring-slate-200;
}

.role-toggle-active:hover {
    @apply bg-white;
}

.role-toggle-compact {
    @apply max-w-[calc(50%-0.5rem)];
}

.devices-filter-divider-vertical {
    @apply hidden h-auto w-px self-stretch bg-slate-200 lg:block;
}

.users-filters-grid {
    @apply grid w-full gap-3 md:grid-cols-2 xl:grid-cols-3;
}

.rooms-filters-grid {
    @apply grid w-full gap-3 md:grid-cols-2 xl:grid-cols-3;
}

.buildings-filters-grid {
    @apply grid w-full gap-3 md:grid-cols-1;
}

.filter-toolbar-footer {
    @apply flex flex-col gap-2 border-t border-slate-200 pt-2 md:flex-row md:items-center md:justify-between;
}

.searchable-select {
    @apply relative;
}

.searchable-select-control {
    @apply relative overflow-visible transition-all duration-200 ease-out;
}

.searchable-select-control-scrubbing {
    @apply z-20;
}

.searchable-select-surface {
    @apply absolute inset-0 z-10 rounded-lg cursor-ns-resize bg-transparent;
    touch-action: none;
}

.searchable-select-toggle {
    @apply absolute right-1.5 top-1/2 z-20 inline-flex h-8 w-8 -translate-y-1/2 items-center justify-center rounded-lg border border-slate-200/70 bg-white/90 text-slate-400 shadow-sm transition hover:border-slate-300 hover:bg-slate-100 hover:text-slate-700 active:scale-[0.98];
}

.searchable-select-toggle-active {
    @apply border-sky-200 bg-sky-50 text-sky-700 ring-2 ring-sky-100;
}

.searchable-select-scrub-preview {
    @apply pointer-events-none absolute inset-x-0 top-1/2 z-30 -translate-y-1/2 overflow-hidden rounded-2xl border border-sky-200 bg-white/95 p-2 shadow-xl ring-1 ring-sky-100 backdrop-blur;
}

.searchable-select-scrub-stack {
    @apply transition-transform duration-200 ease-out;
}

.searchable-select-scrub-row {
    @apply rounded-xl px-3 py-2 text-center;
}

.searchable-select-scrub-row-active {
    @apply bg-slate-900 text-white shadow-sm;
}

.searchable-select-scrub-row-muted {
    @apply text-slate-500;
}

.searchable-select-scrub-label {
    @apply text-sm font-semibold leading-5;
}

.searchable-select-scrub-meta {
    @apply mt-1 text-xs leading-5 opacity-75;
}

.searchable-select-panel {
    @apply absolute right-0 z-[120] mt-2.5 w-full overflow-visible rounded-2xl border border-slate-200 bg-white shadow-[0_28px_55px_-35px_rgba(15,23,42,0.38)] ring-1 ring-slate-100;
}

.searchable-select-list {
    @apply overflow-visible p-2;
    max-height: none;
}

.searchable-select-option {
    @apply flex w-full flex-col rounded-xl px-3 py-2.5 text-left transition;
}

.searchable-select-empty {
    @apply rounded-xl border border-dashed border-slate-200 bg-slate-50 px-3 py-6 text-center text-sm text-slate-500;
}

.localized-date-picker {
    @apply relative;
}

.localized-date-trigger {
    @apply flex w-full items-center justify-between rounded-lg border border-gray-300 bg-white px-2.5 py-2 text-left text-sm shadow-sm transition hover:border-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500;
}

.localized-date-trigger-value {
    @apply truncate;
}

.localized-date-trigger-icon {
    @apply inline-flex h-8 w-8 items-center justify-center rounded-xl border border-slate-200 bg-slate-50 text-slate-500;
}

.localized-date-panel {
    @apply absolute left-0 z-30 mt-2 w-[19rem] rounded-[1.5rem] border border-slate-200 bg-white p-4 shadow-xl ring-1 ring-slate-100;
}

.localized-date-header {
    @apply mb-3 flex items-center justify-between gap-3;
}

.localized-date-title {
    @apply text-sm font-semibold text-slate-900;
}

.localized-date-nav {
    @apply inline-flex h-9 w-9 items-center justify-center rounded-xl border border-slate-200 bg-slate-50 text-slate-700 transition hover:bg-slate-100;
}

.localized-date-weekdays {
    @apply mb-2 grid grid-cols-7 gap-1;
}

.localized-date-weekday {
    @apply px-1 py-1 text-center text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-400;
}

.localized-date-grid {
    @apply grid grid-cols-7 gap-1;
}

.localized-date-cell {
    @apply inline-flex h-10 items-center justify-center rounded-xl text-sm font-medium transition;
}

.localized-date-cell-current {
    @apply bg-white text-slate-700 hover:bg-slate-100;
}

.localized-date-cell-muted {
    @apply text-slate-300 hover:bg-slate-50;
}

.localized-date-cell-selected {
    @apply bg-slate-900 text-white hover:bg-slate-900;
}

.localized-date-actions {
    @apply mt-4 flex flex-wrap justify-between gap-2 border-t border-slate-200 pt-3;
}

.quick-status-filters {
    @apply flex flex-wrap gap-2;
}

.quick-filter-groups {
    @apply flex flex-col gap-3 xl:flex-row xl:items-start xl:justify-between;
}

.quick-filter-group {
    @apply min-w-0 rounded-xl border border-slate-200/90 bg-slate-50/70 px-3 py-2 shadow-sm;
}

.quick-filter-group-end {
    @apply xl:ml-auto;
}

.quick-status-filter {
    @apply inline-flex min-h-[2.25rem] cursor-pointer select-none items-center gap-2 rounded-xl border px-3 py-1.5 text-xs font-semibold leading-none transition-all duration-200;
}

.quick-status-filter:hover {
    @apply -translate-y-0.5 shadow-sm;
}

.quick-status-filter-active {
    @apply ring-2 ring-offset-2 shadow-sm;
}

.quick-status-filter-slate {
    @apply border-slate-200 bg-white text-slate-700 hover:bg-slate-50;
}

.quick-status-filter-slate.quick-status-filter-active {
    @apply border-slate-300 bg-slate-50 text-slate-900 ring-slate-300;
}

.quick-status-filter-emerald {
    @apply border-emerald-200 bg-emerald-50 text-emerald-700 hover:bg-emerald-100;
}

.quick-status-filter-emerald.quick-status-filter-active {
    @apply border-emerald-300 bg-emerald-100 text-emerald-900 ring-emerald-300;
}

.quick-status-filter-amber {
    @apply border-amber-200 bg-amber-50 text-amber-700 hover:bg-amber-100;
}

.quick-status-filter-amber.quick-status-filter-active {
    @apply border-amber-300 bg-amber-100 text-amber-900 ring-amber-300;
}

.quick-status-filter-sky {
    @apply border-sky-200 bg-sky-50 text-sky-700 hover:bg-sky-100;
}

.quick-status-filter-sky.quick-status-filter-active {
    @apply border-sky-300 bg-sky-100 text-sky-900 ring-sky-300;
}

.quick-status-filter-rose {
    @apply border-rose-200 bg-rose-50 text-rose-700 hover:bg-rose-100;
}

.quick-status-filter-rose.quick-status-filter-active {
    @apply border-rose-300 bg-rose-100 text-rose-900 ring-rose-300;
}

.filter-summary {
    @apply mb-3;
    @apply rounded-xl border border-slate-200 bg-white px-3.5 py-2.5 shadow-sm;
}

.filter-summary-head {
    @apply flex items-center gap-1.5 text-xs font-semibold text-slate-600;
}

.filter-summary-items {
    @apply mt-2 flex flex-wrap gap-1.5;
}

.filter-chip {
    @apply inline-flex items-center gap-1.5 rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-[11px] font-medium text-slate-700;
}

.filter-chip-label {
    @apply text-slate-500;
}

.filter-chip-link {
    @apply border-slate-300 bg-white text-slate-700 transition hover:border-slate-400 hover:bg-slate-50;
}

.metric-card {
    @apply rounded-[1.6rem] border border-slate-200 bg-white p-5 shadow-sm;
}

.metric-card-soft-sky {
    @apply border-sky-200 bg-sky-50;
}

.metric-card-soft-emerald {
    @apply border-emerald-200 bg-emerald-50;
}

.metric-card-soft-amber {
    @apply border-amber-200 bg-amber-50;
}

.metric-card-soft-rose {
    @apply border-rose-200 bg-rose-50;
}

.metric-head {
    @apply flex items-center gap-3;
}

.metric-icon {
    @apply inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-white text-slate-700 ring-1 ring-slate-200;
}

.metric-label {
    @apply text-xs font-semibold uppercase tracking-[0.18em] text-slate-500;
}

.metric-value {
    @apply mt-3 text-3xl font-semibold text-slate-900;
}

.metric-note {
    @apply mt-1 text-sm text-slate-600;
}

.status-pill {
    @apply inline-flex min-h-[2.125rem] items-center gap-2 rounded-full px-3 py-1.5 text-xs font-semibold leading-none whitespace-nowrap ring-1;
}

.status-pill-neutral {
    @apply bg-slate-100 text-slate-700 ring-slate-200;
}

.status-pill-info {
    @apply bg-sky-100 text-sky-800 ring-sky-200;
}

.status-pill-success {
    @apply bg-emerald-100 text-emerald-800 ring-emerald-200;
}

.status-pill-warning {
    @apply bg-amber-100 text-amber-800 ring-amber-200;
}

.status-pill-danger {
    @apply bg-rose-100 text-rose-800 ring-rose-200;
}

.status-pill-violet {
    @apply bg-violet-100 text-violet-800 ring-violet-200;
}

.audit-badge {
    @apply inline-flex min-h-[2.125rem] items-center gap-2 rounded-full px-3 py-1.5 text-xs font-semibold leading-none whitespace-nowrap ring-1;
}

.audit-badge-slate {
    @apply bg-slate-100 text-slate-700 ring-slate-200;
}

.audit-badge-sky {
    @apply bg-sky-100 text-sky-800 ring-sky-200;
}

.audit-badge-emerald {
    @apply bg-emerald-100 text-emerald-800 ring-emerald-200;
}

.audit-badge-amber {
    @apply bg-amber-100 text-amber-800 ring-amber-200;
}

.audit-badge-rose {
    @apply bg-rose-100 text-rose-800 ring-rose-200;
}

.audit-badge-violet {
  @apply bg-violet-100 text-violet-800 ring-violet-200;
}

.audit-entity-cell {
  @apply relative flex min-w-0 flex-col gap-2;
}

.audit-entity-reference {
  @apply line-clamp-2 text-sm font-medium leading-5 text-slate-700;
}

.audit-entity-link {
  @apply font-semibold text-sky-600 underline decoration-slate-300 underline-offset-4 transition hover:text-sky-700 hover:decoration-sky-300;
}

.audit-entity-preview {
  @apply pointer-events-none invisible absolute left-0 top-full z-30 mt-2 w-72 rounded-2xl border border-slate-200 bg-white p-4 text-left opacity-0 shadow-xl transition duration-200;
}

.audit-entity-cell:hover .audit-entity-preview,
.audit-entity-cell:focus-within .audit-entity-preview {
  @apply visible opacity-100;
}

.audit-entity-preview-title {
  @apply text-sm font-semibold text-slate-900;
}

.audit-entity-preview-line {
  @apply mt-1 text-xs leading-5 text-slate-600;
}

.audit-date-stack {
  @apply flex flex-col gap-1;
}

.audit-date-value {
  @apply font-semibold text-slate-900;
}

.audit-time-value {
  @apply text-xs font-medium tracking-[0.08em] text-slate-500;
}

.audit-description-text {
  @apply break-words text-sm font-medium leading-6 text-slate-700;
}

/* Shared action buttons */
.btn-action {
    @apply inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-xl px-4 py-2.5 text-sm font-semibold shadow-sm transition;
}

.btn-create {
    @apply inline-flex items-center justify-center gap-1.5 whitespace-nowrap rounded-lg bg-emerald-600 px-3.5 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2;
}

.btn-submit {
    @apply inline-flex items-center justify-center gap-2 whitespace-nowrap rounded-lg bg-sky-600 px-3.5 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-sky-700 focus:outline-none focus:ring-2 focus:ring-sky-500 focus:ring-offset-2;
}

.btn-search,
.devices-code-search-btn {
    @apply inline-flex items-center justify-center gap-1.5 whitespace-nowrap rounded-lg bg-sky-600 px-3.5 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-sky-700 focus:outline-none focus:ring-2 focus:ring-sky-500 focus:ring-offset-2;
}

.request-detail-overlay {
    position: fixed;
    inset: 0;
    z-index: 78;
    display: flex;
    justify-content: flex-end;
    padding-left: 1rem;
}

.request-detail-backdrop {
    position: absolute;
    inset: 0;
    background:
        radial-gradient(circle at 12% 18%, rgba(56, 189, 248, 0.14), transparent 24%),
        rgba(15, 23, 42, 0.62);
    backdrop-filter: blur(10px);
}

.request-detail-panel {
    position: relative;
    z-index: 1;
    display: flex;
    height: 100%;
    width: min(34rem, 100vw);
    flex-direction: column;
    gap: 0;
    overflow: hidden;
    border-left: 1px solid rgba(148, 163, 184, 0.28);
    background:
        radial-gradient(circle at top right, rgba(59, 130, 246, 0.18), transparent 34%),
        radial-gradient(circle at bottom left, rgba(14, 165, 233, 0.08), transparent 28%),
        linear-gradient(180deg, rgba(255, 255, 255, 0.99), rgba(248, 250, 252, 0.98));
    box-shadow: -28px 0 70px rgba(15, 23, 42, 0.24);
}

.request-detail-panel-audit {
    width: min(38rem, 100vw);
}

.request-detail-panel-repair {
    width: min(35rem, 100vw);
}

:root[data-theme='dark'] .request-detail-panel {
    border-left-color: rgba(71, 85, 105, 0.55);
    background:
        radial-gradient(circle at top right, rgba(56, 189, 248, 0.14), transparent 36%),
        linear-gradient(180deg, rgba(15, 23, 42, 0.98), rgba(17, 24, 39, 0.98));
    box-shadow: -24px 0 60px rgba(2, 6, 23, 0.58);
}

.request-detail-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.35rem 1.35rem 1rem;
    border-bottom: 1px solid rgba(148, 163, 184, 0.14);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.45), rgba(255, 255, 255, 0));
    backdrop-filter: blur(8px);
}

.request-detail-head-copy {
    min-width: 0;
}

.request-detail-eyebrow {
    color: #64748b;
    font-size: 0.73rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
}

.request-detail-title {
    margin-top: 0.55rem;
    color: #0f172a;
    font-size: 1.55rem;
    font-weight: 700;
    line-height: 1.2;
}

.request-detail-subtitle {
    margin-top: 0.55rem;
    color: #475569;
    font-size: 0.95rem;
    line-height: 1.65;
}

.request-detail-close {
    display: inline-flex;
    height: 2.75rem;
    width: 2.75rem;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    border: 1px solid rgba(148, 163, 184, 0.32);
    background: rgba(255, 255, 255, 0.88);
    color: #475569;
    box-shadow: 0 10px 20px rgba(15, 23, 42, 0.08);
    transition: 180ms ease;
}

.request-detail-close:hover {
    border-color: rgba(59, 130, 246, 0.4);
    background: rgba(239, 246, 255, 0.94);
    color: #0f172a;
}

.request-detail-body {
    display: flex;
    flex: 1 1 auto;
    flex-direction: column;
    gap: 1rem;
    overflow-y: auto;
    padding: 1rem 1.35rem 1.2rem;
}

.request-detail-hero {
    display: flex;
    align-items: flex-start;
    gap: 0.9rem;
    border: 1px solid rgba(148, 163, 184, 0.18);
    border-radius: 1.4rem;
    background:
        linear-gradient(135deg, rgba(255, 255, 255, 0.96), rgba(241, 245, 249, 0.92)),
        radial-gradient(circle at top right, rgba(14, 165, 233, 0.1), transparent 52%);
    box-shadow: 0 18px 32px rgba(15, 23, 42, 0.08);
    padding: 1.05rem 1.05rem;
}

.request-detail-hero-mark {
    display: inline-flex;
    height: 2.9rem;
    width: 2.9rem;
    flex: 0 0 auto;
    align-items: center;
    justify-content: center;
    border-radius: 1rem;
    background: linear-gradient(135deg, rgba(14, 165, 233, 0.14), rgba(59, 130, 246, 0.18));
    color: #0369a1;
    box-shadow: inset 0 0 0 1px rgba(125, 211, 252, 0.35);
}

.request-detail-hero-copy {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.22rem;
}

.request-detail-hero-title {
    color: #0f172a;
    font-size: 1.06rem;
    font-weight: 700;
    line-height: 1.35;
    word-break: break-word;
}

.request-detail-hero-meta {
    color: #475569;
    font-size: 0.9rem;
    line-height: 1.55;
}

.request-detail-hero-note {
    color: #64748b;
    font-size: 0.8rem;
    line-height: 1.55;
}

.request-detail-summary,
.request-detail-card,
.request-detail-summary-card {
    border: 1px solid rgba(148, 163, 184, 0.18);
    border-radius: 1.35rem;
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 18px 32px rgba(15, 23, 42, 0.08);
}

.request-detail-summary-grid {
    display: grid;
    gap: 0.85rem;
    grid-template-columns: repeat(auto-fit, minmax(9.5rem, 1fr));
}

.request-detail-summary-card {
    padding: 0.95rem 1rem;
}

.request-detail-summary-head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
}

.request-detail-summary-label {
    color: #64748b;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
}

.request-detail-summary-value {
    margin-top: 0.7rem;
    color: #0f172a;
    font-size: 0.98rem;
    font-weight: 700;
    line-height: 1.45;
    word-break: break-word;
}

.request-detail-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.1rem;
}

.request-detail-status-wrap {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
}

.request-detail-status {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    padding: 0.42rem 0.9rem;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
}

.request-detail-status-amber {
    background: rgba(254, 243, 199, 0.96);
    color: #b45309;
}

.request-detail-status-emerald {
    background: rgba(209, 250, 229, 0.96);
    color: #047857;
}

.request-detail-status-sky {
    background: rgba(224, 242, 254, 0.96);
    color: #0369a1;
}

.request-detail-status-slate {
    background: rgba(241, 245, 249, 0.96);
    color: #475569;
}

.request-detail-status-violet {
    background: rgba(237, 233, 254, 0.96);
    color: #6d28d9;
}

.request-detail-status-rose {
    background: rgba(255, 228, 230, 0.96);
    color: #be123c;
}

.request-detail-date {
    color: #64748b;
    font-size: 0.8rem;
    font-weight: 600;
}

.request-detail-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border-radius: 9999px;
    background: rgba(14, 165, 233, 0.1);
    color: #0369a1;
    padding: 0.72rem 1rem;
    font-size: 0.84rem;
    font-weight: 700;
    transition: 180ms ease;
}

.request-detail-link:hover {
    background: rgba(14, 165, 233, 0.16);
    color: #075985;
}

.request-detail-link-inline {
    margin-top: 0.85rem;
    width: fit-content;
}

.request-detail-inline-action {
    display: flex;
    justify-content: flex-start;
}

.request-detail-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
}

.request-detail-card {
    padding: 1rem 1.05rem;
}

.request-detail-card-wide {
    padding: 1rem 1.1rem;
}

.request-detail-card-muted {
    background: linear-gradient(180deg, rgba(248, 250, 252, 0.92), rgba(255, 255, 255, 0.9));
}

.request-detail-card-head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
}

.request-detail-card-icon {
    display: inline-flex;
    height: 1.9rem;
    width: 1.9rem;
    flex: 0 0 auto;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    background: rgba(14, 165, 233, 0.1);
    color: #0369a1;
    box-shadow: inset 0 0 0 1px rgba(125, 211, 252, 0.26);
}

.request-detail-icon-tone-slate {
    background: rgba(241, 245, 249, 0.96);
    color: #475569;
    box-shadow: inset 0 0 0 1px rgba(148, 163, 184, 0.28);
}

.request-detail-icon-tone-sky {
    background: rgba(224, 242, 254, 0.96);
    color: #0369a1;
    box-shadow: inset 0 0 0 1px rgba(125, 211, 252, 0.26);
}

.request-detail-icon-tone-amber {
    background: rgba(254, 243, 199, 0.96);
    color: #b45309;
    box-shadow: inset 0 0 0 1px rgba(251, 191, 36, 0.24);
}

.request-detail-icon-tone-emerald {
    background: rgba(209, 250, 229, 0.96);
    color: #047857;
    box-shadow: inset 0 0 0 1px rgba(52, 211, 153, 0.24);
}

.request-detail-icon-tone-violet {
    background: rgba(237, 233, 254, 0.96);
    color: #6d28d9;
    box-shadow: inset 0 0 0 1px rgba(167, 139, 250, 0.24);
}

.request-detail-icon-tone-rose {
    background: rgba(255, 228, 230, 0.96);
    color: #be123c;
    box-shadow: inset 0 0 0 1px rgba(251, 113, 133, 0.24);
}

.request-detail-card-label {
    color: #64748b;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
}

.request-detail-card-value {
    margin-top: 0.55rem;
    color: #0f172a;
    font-size: 1rem;
    font-weight: 700;
}

.request-detail-card-meta,
.request-detail-card-note {
    margin-top: 0.35rem;
    color: #475569;
    font-size: 0.86rem;
    line-height: 1.55;
}

.request-detail-card-stack {
    display: flex;
    flex-direction: column;
    gap: 0.18rem;
}

.request-detail-copy {
    margin-top: 0.75rem;
    color: #1e293b;
    font-size: 0.92rem;
    line-height: 1.75;
    white-space: pre-wrap;
}

.request-detail-detail-block {
    margin-top: 0.85rem;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
}

.request-detail-detail-highlight {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    border-radius: 1rem;
    background: rgba(248, 250, 252, 0.9);
    padding: 0.85rem 0.95rem;
}

.request-detail-detail-label {
    color: #64748b;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
}

.request-detail-detail-value {
    color: #0f172a;
    font-size: 0.92rem;
    font-weight: 600;
    line-height: 1.6;
}

.request-detail-detail-list {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
}

.request-detail-detail-row {
    display: flex;
    align-items: flex-start;
    gap: 0.7rem;
    color: #334155;
    font-size: 0.88rem;
    line-height: 1.65;
}

.request-detail-detail-dot {
    margin-top: 0.5rem;
    height: 0.42rem;
    width: 0.42rem;
    flex: 0 0 auto;
    border-radius: 9999px;
    background: linear-gradient(135deg, #0ea5e9, #2563eb);
    box-shadow: 0 0 0 4px rgba(14, 165, 233, 0.08);
}

.request-detail-foot {
    display: flex;
    justify-content: flex-end;
    border-top: 1px solid rgba(148, 163, 184, 0.14);
    padding: 1rem 1.35rem 1.2rem;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0), rgba(248, 250, 252, 0.86));
}

:root[data-theme='dark'] .request-detail-eyebrow,
:root[data-theme='dark'] .request-detail-date,
:root[data-theme='dark'] .request-detail-card-label,
:root[data-theme='dark'] .request-detail-summary-label,
:root[data-theme='dark'] .request-detail-detail-label {
    color: #94a3b8;
}

:root[data-theme='dark'] .request-detail-title,
:root[data-theme='dark'] .request-detail-hero-title,
:root[data-theme='dark'] .request-detail-card-value,
:root[data-theme='dark'] .request-detail-copy,
:root[data-theme='dark'] .request-detail-summary-value,
:root[data-theme='dark'] .request-detail-detail-value {
    color: #e2e8f0;
}

:root[data-theme='dark'] .request-detail-subtitle,
:root[data-theme='dark'] .request-detail-hero-meta,
:root[data-theme='dark'] .request-detail-card-meta,
:root[data-theme='dark'] .request-detail-card-note {
    color: #cbd5e1;
}

:root[data-theme='dark'] .request-detail-hero-note {
    color: #94a3b8;
}

:root[data-theme='dark'] .request-detail-close {
    border-color: rgba(71, 85, 105, 0.55);
    background: rgba(15, 23, 42, 0.9);
    color: #cbd5e1;
}

:root[data-theme='dark'] .request-detail-close:hover {
    border-color: rgba(56, 189, 248, 0.35);
    background: rgba(15, 23, 42, 0.98);
    color: #f8fafc;
}

:root[data-theme='dark'] .request-detail-head {
    border-bottom-color: rgba(71, 85, 105, 0.38);
    background: linear-gradient(180deg, rgba(15, 23, 42, 0.34), rgba(15, 23, 42, 0));
}

:root[data-theme='dark'] .request-detail-summary,
:root[data-theme='dark'] .request-detail-card,
:root[data-theme='dark'] .request-detail-summary-card,
:root[data-theme='dark'] .request-detail-hero {
    border-color: rgba(71, 85, 105, 0.45);
    background: rgba(15, 23, 42, 0.9);
    box-shadow: 0 18px 32px rgba(2, 6, 23, 0.3);
}

:root[data-theme='dark'] .request-detail-hero {
    background:
        linear-gradient(135deg, rgba(15, 23, 42, 0.96), rgba(17, 24, 39, 0.92)),
        radial-gradient(circle at top right, rgba(56, 189, 248, 0.14), transparent 55%);
}

:root[data-theme='dark'] .request-detail-hero-mark {
    background: linear-gradient(135deg, rgba(14, 165, 233, 0.18), rgba(37, 99, 235, 0.22));
    color: #bae6fd;
    box-shadow: inset 0 0 0 1px rgba(56, 189, 248, 0.28);
}

:root[data-theme='dark'] .request-detail-card-icon {
    background: rgba(14, 165, 233, 0.16);
    color: #7dd3fc;
    box-shadow: inset 0 0 0 1px rgba(56, 189, 248, 0.22);
}

:root[data-theme='dark'] .request-detail-icon-tone-slate {
    background: rgba(51, 65, 85, 0.7);
    color: #cbd5e1;
    box-shadow: inset 0 0 0 1px rgba(100, 116, 139, 0.32);
}

:root[data-theme='dark'] .request-detail-icon-tone-sky {
    background: rgba(14, 165, 233, 0.18);
    color: #7dd3fc;
    box-shadow: inset 0 0 0 1px rgba(56, 189, 248, 0.22);
}

:root[data-theme='dark'] .request-detail-icon-tone-amber {
    background: rgba(245, 158, 11, 0.16);
    color: #fcd34d;
    box-shadow: inset 0 0 0 1px rgba(245, 158, 11, 0.22);
}

:root[data-theme='dark'] .request-detail-icon-tone-emerald {
    background: rgba(16, 185, 129, 0.16);
    color: #6ee7b7;
    box-shadow: inset 0 0 0 1px rgba(16, 185, 129, 0.22);
}

:root[data-theme='dark'] .request-detail-icon-tone-violet {
    background: rgba(139, 92, 246, 0.18);
    color: #c4b5fd;
    box-shadow: inset 0 0 0 1px rgba(139, 92, 246, 0.22);
}

:root[data-theme='dark'] .request-detail-icon-tone-rose {
    background: rgba(244, 63, 94, 0.18);
    color: #fda4af;
    box-shadow: inset 0 0 0 1px rgba(244, 63, 94, 0.22);
}

:root[data-theme='dark'] .request-detail-link {
    background: rgba(14, 165, 233, 0.16);
    color: #7dd3fc;
}

:root[data-theme='dark'] .request-detail-link:hover {
    background: rgba(14, 165, 233, 0.22);
    color: #bae6fd;
}

:root[data-theme='dark'] .request-detail-card-muted {
    background: linear-gradient(180deg, rgba(15, 23, 42, 0.96), rgba(17, 24, 39, 0.9));
}

:root[data-theme='dark'] .request-detail-detail-highlight {
    background: rgba(30, 41, 59, 0.78);
}

:root[data-theme='dark'] .request-detail-detail-row {
    color: #cbd5e1;
}

:root[data-theme='dark'] .request-detail-detail-dot {
    box-shadow: 0 0 0 4px rgba(56, 189, 248, 0.12);
}

:root[data-theme='dark'] .request-detail-foot {
    border-top-color: rgba(71, 85, 105, 0.38);
    background: linear-gradient(180deg, rgba(15, 23, 42, 0), rgba(15, 23, 42, 0.74));
}

.btn-clear {
    @apply inline-flex items-center justify-center gap-1.5 whitespace-nowrap rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 shadow-sm transition hover:bg-slate-50;
}

.btn-view {
    @apply inline-flex items-center justify-center gap-1.5 whitespace-nowrap rounded-lg border border-sky-200 bg-sky-50 px-3.5 py-2 text-sm font-semibold text-sky-700 shadow-sm transition hover:bg-sky-100;
}

.btn-edit {
    @apply inline-flex items-center justify-center gap-1.5 whitespace-nowrap rounded-lg border border-amber-200 bg-amber-50 px-3.5 py-2 text-sm font-semibold text-amber-700 shadow-sm transition hover:bg-amber-100;
}

.btn-back {
    @apply inline-flex items-center justify-center gap-1.5 whitespace-nowrap rounded-lg border border-slate-300 bg-white px-3.5 py-2 text-sm font-semibold text-slate-700 shadow-sm transition hover:bg-slate-50;
}

.btn-danger {
    @apply inline-flex items-center justify-center gap-1.5 whitespace-nowrap rounded-lg border border-rose-200 bg-rose-50 px-3.5 py-2 text-sm font-semibold text-rose-700 shadow-sm transition hover:bg-rose-100;
}

.btn-disabled {
    @apply inline-flex items-center justify-start gap-1.5 whitespace-nowrap rounded-lg border border-slate-200 bg-slate-100 px-3.5 py-2 text-sm font-semibold text-slate-500 shadow-sm transition hover:bg-slate-200 cursor-not-allowed;
}

.btn-danger-solid {
    @apply inline-flex items-center justify-center gap-1.5 whitespace-nowrap rounded-lg bg-rose-600 px-3.5 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-rose-700 focus:outline-none focus:ring-2 focus:ring-rose-500 focus:ring-offset-2;
}

.btn-approve {
    @apply inline-flex items-center justify-center gap-1.5 whitespace-nowrap rounded-lg bg-emerald-600 px-3.5 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:ring-offset-2;
}

.btn-reject {
    @apply inline-flex items-center justify-center gap-1.5 whitespace-nowrap rounded-lg border border-rose-200 bg-rose-50 px-3.5 py-2 text-sm font-semibold text-rose-700 shadow-sm transition hover:bg-rose-100;
}

.table-action-menu {
    @apply relative inline-block;
}

.table-action-summary {
    @apply inline-flex h-9 cursor-pointer items-center justify-between gap-2 rounded-xl border border-slate-200 bg-white px-3 text-sm font-semibold text-slate-700 shadow-sm transition-all duration-200 hover:border-slate-300 hover:bg-slate-50 hover:text-slate-900;
}

.table-action-summary svg {
    @apply h-4 w-4 text-slate-400 transition-all duration-200;
}

.table-action-summary:hover svg {
    @apply text-slate-600;
}

.table-action-summary[aria-expanded="true"] {
    @apply border-sky-200 bg-sky-50 text-sky-700 shadow-sm;
}

.table-action-summary[aria-expanded="true"] svg {
    @apply rotate-180 text-sky-600;
}

.table-action-list {
