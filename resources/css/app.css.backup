    @apply absolute right-4 top-4 shrink-0;
}

.flash-toast {
    @apply pointer-events-auto relative flex items-start gap-3 overflow-hidden rounded-[1.35rem] border px-4 py-3 shadow-2xl backdrop-blur;
}

.flash-toast::before {
    content: '';
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    opacity: 0.95;
}

.flash-toast::after {
    content: '';
    position: absolute;
    right: -2.25rem;
    top: -2.25rem;
    height: 6.5rem;
    width: 6.5rem;
    border-radius: 9999px;
    pointer-events: none;
    filter: blur(12px);
    opacity: 0.28;
}

.flash-toast-icon {
    @apply inline-flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl border text-sm font-semibold shadow-sm;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.18), 0 14px 28px -20px rgba(15, 23, 42, 0.35);
}

.flash-toast-body {
    @apply min-w-0 flex-1 pt-0.5;
}

.flash-toast-title {
    @apply text-xs font-semibold uppercase tracking-[0.18em] text-slate-500;
}

.flash-toast-message {
    @apply mt-1 text-sm font-medium text-slate-900;
}

.flash-toast-close {
    @apply inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-2xl border border-black/5 bg-white/80 text-slate-500 transition hover:-translate-y-0.5 hover:bg-white hover:text-slate-900;
    box-shadow: 0 10px 22px -18px rgba(15, 23, 42, 0.34);
}

.flash-toast-success {
    @apply border-emerald-200 bg-emerald-50/95 text-emerald-900;
}

.flash-toast-success::before {
    background: linear-gradient(90deg, rgba(16, 185, 129, 0.98), rgba(52, 211, 153, 0.82));
}

.flash-toast-success::after {
    background: radial-gradient(circle, rgba(52, 211, 153, 0.34) 0%, rgba(52, 211, 153, 0) 72%);
}

.flash-toast-success .flash-toast-icon {
    @apply border-emerald-200 bg-emerald-100 text-emerald-700;
}

.flash-toast-info {
    @apply border-sky-200 bg-sky-50/95 text-sky-950;
}

.flash-toast-info::before {
    background: linear-gradient(90deg, rgba(14, 165, 233, 0.98), rgba(56, 189, 248, 0.82));
}

.flash-toast-info::after {
    background: radial-gradient(circle, rgba(56, 189, 248, 0.34) 0%, rgba(56, 189, 248, 0) 72%);
}

.flash-toast-info .flash-toast-icon {
    @apply border-sky-200 bg-sky-100 text-sky-700;
}

.flash-toast-error {
    @apply border-rose-200 bg-rose-50/95 text-rose-950;
}

.flash-toast-error::before {
    background: linear-gradient(90deg, rgba(244, 63, 94, 0.98), rgba(251, 113, 133, 0.82));
}

.flash-toast-error::after {
    background: radial-gradient(circle, rgba(251, 113, 133, 0.32) 0%, rgba(251, 113, 133, 0) 72%);
}

.flash-toast-error .flash-toast-icon {
    @apply border-rose-200 bg-rose-100 text-rose-700;
}

.notification-toast-actions {
    @apply border-black/5;
}

.notification-toast-actions .btn-approve,
.notification-toast-actions .btn-reject,
.notification-toast-actions button {
    @apply min-w-[8.5rem] flex-1;
}

@media (max-width: 640px) {
    .notification-toast-main {
        @apply pr-10;
    }

    .notification-toast-topline {
        @apply gap-1.5;
    }

    .notification-toast-title {
        @apply text-[15px] leading-6;
    }
}

.device-repair-state-chip {
    @apply inline-flex items-center gap-1.5 rounded-full border border-amber-200 bg-amber-50 px-3 py-1.5 text-xs font-semibold text-amber-800;
}

.device-table-thumb {
    @apply mx-auto h-11 w-11 rounded-xl object-cover ring-1 ring-slate-200;
}

.device-table-thumb-placeholder {
    @apply flex items-center justify-center bg-slate-100 text-slate-400;
}

/* Device search highlight animation */
@keyframes device-search-pulse {
    0%, 100% {
        box-shadow: 0 0 0 0 rgba(14, 165, 233, 0.7);
        background-color: rgba(14, 165, 233, 0.1);
    }
    50% {
        box-shadow: 0 0 0 8px rgba(14, 165, 233, 0);
        background-color: rgba(14, 165, 233, 0.2);
    }
}

.device-file-input {
    @apply w-full rounded-[1.25rem] border border-dashed border-slate-300 bg-slate-50 px-4 py-3 text-sm text-slate-600 file:mr-4 file:rounded-xl file:border-0 file:bg-slate-900 file:px-4 file:py-2 file:font-semibold file:text-white hover:file:bg-slate-800;
}

/* Auth enhancements */
.btn-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
}

/* REMOVED CSS: */

/* REMOVED CSS: */

/* REMOVED CSS: */

/* REMOVED CSS: */

/* REMOVED CSS: */

/* Theme switcher and dark mode */
:root {
    color-scheme: light;
}

.app-bg,
.guest-bg {
    background-repeat: no-repeat;
    background-attachment: scroll;
    background-position: center top;
    background-size: cover;
    min-height: 100vh;
    position: relative;
    isolation: isolate;
}

html[data-theme='dark'] {
    color-scheme: dark;
}

.theme-choice-group {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.55rem;
}

.theme-choice-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    border-radius: 1rem;
    border: 1px solid rgba(203, 213, 225, 0.95);
    background: rgba(248, 250, 252, 0.92);
    color: rgb(51 65 85);
    padding: 0.75rem 0.85rem;
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    line-height: 1;
    text-transform: uppercase;
    transition: background-color 0.18s ease, border-color 0.18s ease, color 0.18s ease, transform 0.18s ease, box-shadow 0.18s ease;
}

.theme-choice-btn:hover {
    transform: translateY(-1px);
    background: rgba(241, 245, 249, 0.98);
    color: rgb(15 23 42);
}

.theme-choice-btn[data-active='true'] {
    background: linear-gradient(135deg, #0f172a 0%, #1d4ed8 100%);
    border-color: rgba(29, 78, 216, 0.55);
    color: #fff;
    box-shadow: 0 14px 28px -22px rgba(29, 78, 216, 0.7);
}

.app-brand-title,
.app-brand-subtitle {
    transition: color 0.2s ease;
}

.app-brand-crest,
.app-brand-fallback {
    transition: background-color 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
}

html[data-theme='dark'] body {
    background-color: #020617;
    color: #e2e8f0;
}

html[data-theme='dark'] .app-bg {
    background: transparent !important;
    color: #e2e8f0;
}

html[data-theme='dark'] .guest-bg {
    background: transparent !important;
    color: #e2e8f0;
}

html[data-theme='dark'] .auth-wrapper,
html[data-theme='dark'] .auth-left {
    background: transparent !important;
}

html[data-theme='dark'] .auth-right {
    background:
        radial-gradient(circle at top left, rgba(56, 189, 248, 0.16), transparent 34%),
        linear-gradient(160deg, rgba(2, 6, 23, 0.92) 0%, rgba(15, 23, 42, 0.96) 38%, rgba(29, 78, 216, 0.78) 100%) !important;
    border-left: 1px solid rgba(51, 65, 85, 0.72);
}

html[data-theme='dark'] .auth-right::before {
    background:
        radial-gradient(circle, rgba(14, 165, 233, 0.44) 0%, rgba(29, 78, 216, 0.26) 42%, transparent 74%);
}

html[data-theme='dark'] .auth-right::after {
    background:
        radial-gradient(circle, rgba(96, 165, 250, 0.34) 0%, rgba(56, 189, 248, 0.24) 38%, transparent 74%);
}

html[data-theme='dark'] .app-bg::before,
html[data-theme='dark'] .guest-bg::before {
    content: '';
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background:
        radial-gradient(52rem 30rem at 8% 0%, rgba(14, 165, 233, 0.20), transparent 68%),
        radial-gradient(44rem 24rem at 92% 8%, rgba(16, 185, 129, 0.14), transparent 66%),
        radial-gradient(48rem 28rem at 18% 34%, rgba(29, 78, 216, 0.18), transparent 70%),
        radial-gradient(40rem 24rem at 86% 58%, rgba(14, 165, 233, 0.12), transparent 68%),
        radial-gradient(44rem 26rem at 20% 84%, rgba(37, 99, 235, 0.14), transparent 70%),
        radial-gradient(38rem 22rem at 88% 98%, rgba(14, 165, 233, 0.10), transparent 72%),
        linear-gradient(180deg, #020617 0%, #0f172a 46%, #111827 100%);
    background-repeat: no-repeat;
    background-size: auto;
    background-position: center top;
}

html[data-theme='dark'] .guest-bg::before {
    background:
        radial-gradient(48rem 28rem at 8% 0%, rgba(14, 165, 233, 0.22), transparent 68%),
        radial-gradient(42rem 24rem at 90% 12%, rgba(16, 185, 129, 0.14), transparent 66%),
        radial-gradient(44rem 26rem at 15% 48%, rgba(37, 99, 235, 0.16), transparent 70%),
        radial-gradient(40rem 22rem at 86% 88%, rgba(14, 165, 233, 0.10), transparent 72%),
        linear-gradient(180deg, #020617 0%, #0f172a 55%, #111827 100%);
}

html[data-theme='dark'] .app-main-nav {
    background: rgba(2, 6, 23, 0.84) !important;
    border-color: rgba(30, 41, 59, 0.92) !important;
    box-shadow: 0 18px 38px -30px rgba(2, 6, 23, 0.95);
}

html[data-theme='dark'] .theme-choice-btn {
    border-color: rgba(71, 85, 105, 0.9);
    background: rgba(15, 23, 42, 0.92);
    color: #cbd5e1;
}

html[data-theme='dark'] .theme-choice-btn:hover {
