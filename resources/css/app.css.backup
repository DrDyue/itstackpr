}

.form-page-grid {
    @apply grid gap-6 xl:grid-cols-[minmax(0,1fr)_20rem];
}

.form-page-main {
    @apply min-w-0;
}

.form-page-aside {
    @apply space-y-4;
}

.form-page-note {
    @apply rounded-[1.5rem] border border-slate-200 bg-slate-50/90 px-5 py-4 text-sm leading-6 text-slate-600;
}

.form-page-note-title {
