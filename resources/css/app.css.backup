.request-type-section {
    @apply pt-1;
}

.request-type-divider {
    @apply flex items-center gap-4;
}

.request-type-divider-line {
    @apply h-px flex-1;
    background: linear-gradient(90deg, rgba(148, 163, 184, 0.05), rgba(148, 163, 184, 0.55), rgba(148, 163, 184, 0.05));
}

.request-type-divider-chip {
    @apply inline-flex items-center gap-3 rounded-full border px-4 py-3 text-xs font-extrabold uppercase tracking-[0.18em] shadow-sm;
    border-color: rgba(226, 232, 240, 0.95);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(248, 250, 252, 0.94));
    color: rgb(51 65 85);
}

.request-type-divider-icon {
    @apply inline-flex h-8 w-8 items-center justify-center rounded-full bg-white/95;
}

.request-type-divider-count {
    @apply rounded-full bg-white/90 px-2.5 py-1 text-[11px] tracking-[0.08em];
}

.request-type-divider-note {
    @apply mb-4 mt-3 text-center text-sm text-slate-500;
}

.request-type-divider-amber .request-type-divider-chip {
    border-color: rgba(251, 191, 36, 0.35);
    background: linear-gradient(180deg, rgba(255, 251, 235, 0.98), rgba(255, 247, 237, 0.94));
    color: rgb(146 64 14);
}

.request-type-divider-amber .request-type-divider-icon,
.request-type-divider-amber .request-type-divider-count {
    color: rgb(180 83 9);
    background: rgba(255, 255, 255, 0.82);
}

.request-type-divider-rose .request-type-divider-chip {
    border-color: rgba(251, 113, 133, 0.35);
    background: linear-gradient(180deg, rgba(255, 241, 242, 0.98), rgba(255, 245, 245, 0.94));
    color: rgb(159 18 57);
}

.request-type-divider-rose .request-type-divider-icon,
.request-type-divider-rose .request-type-divider-count {
    color: rgb(190 24 93);
    background: rgba(255, 255, 255, 0.82);
}

.request-type-divider-emerald .request-type-divider-chip {
    border-color: rgba(52, 211, 153, 0.35);
    background: linear-gradient(180deg, rgba(236, 253, 245, 0.98), rgba(240, 253, 250, 0.94));
    color: rgb(6 95 70);
}

.request-type-divider-emerald .request-type-divider-icon,
.request-type-divider-emerald .request-type-divider-count {
    color: rgb(5 150 105);
    background: rgba(255, 255, 255, 0.82);
}

@media (max-width: 640px) {
    .request-type-divider {
        @apply gap-2.5;
    }

    .request-type-divider-chip {
        @apply w-full justify-center gap-2.5 px-4 py-3 tracking-[0.12em];
    }

    .request-type-divider-line {
        @apply hidden;
    }
}

