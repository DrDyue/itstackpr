.dash-bottom-grid {
    @apply mt-6 grid gap-5;
}

.dash-table-wrap {
    @apply overflow-visible p-4;
}

.dash-table {
    @apply min-w-full text-sm;
}

.dash-table-head {
    @apply border-b border-slate-200 bg-slate-50 text-xs uppercase tracking-[0.18em] text-slate-500;
}

.dash-table-head th {
