.dash-device-list {
    @apply mt-5 space-y-3;
}

.dash-device-card {
    @apply block rounded-[1.45rem] border border-slate-200 bg-slate-50/70 p-4 shadow-sm transition hover:-translate-y-0.5 hover:border-sky-200 hover:bg-white;
}

.dash-device-head {
    @apply flex flex-wrap items-start justify-between gap-3;
}

.dash-device-title {
    @apply text-base font-semibold text-slate-900;
}

.dash-device-subtitle {
    @apply mt-1 text-xs text-slate-500;
}

.dash-device-grid {
    @apply mt-4 grid gap-3 md:grid-cols-2;
}

.dash-device-metric {
    @apply rounded-xl bg-white px-3 py-3 ring-1 ring-slate-200;
}

.dash-device-label {
    @apply text-[11px] font-semibold uppercase tracking-[0.16em] text-slate-500;
}

.dash-device-value {
    @apply mt-1 text-sm font-medium text-slate-700;
}

.dash-split-grid {
    @apply grid gap-6 xl:grid-cols-2;
}

@media (min-width: 1024px) {
    .dash-toolbar {
        grid-template-columns: minmax(0, 1.2fr) auto auto;
        align-items: center;
    }
}

@media (min-width: 1280px) {
    .dash-layout-grid {
        grid-template-columns: 320px minmax(0, 1fr) 300px;
    }
}

@media (max-width: 767px) {
    .dash-kpi-grid,
    .dash-quick-grid {
        @apply grid-cols-1;
    }

    .dash-workspace-grid,
    .dash-split-grid,
    .dash-device-grid {
        @apply grid-cols-1;
    }

    .dash-toolbar {
        @apply p-4;
    }
}

