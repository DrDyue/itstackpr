}

/* REMOVED CSS: */

.app-confirm-overlay.is-visible {
    pointer-events: auto;
    opacity: 1;
}

.app-confirm-overlay .app-confirm-dialog {
    transform: translateY(18px) scale(0.96);
    transition: transform 220ms ease, opacity 220ms ease, box-shadow 220ms ease;
}

.app-confirm-overlay.is-visible .app-confirm-dialog {
    transform: translateY(0) scale(1);
}

/* REMOVED CSS: */

/* REMOVED CSS: */

.app-confirm-dialog::before,
.app-confirm-dialog::after {
    content: '';
    position: absolute;
    border-radius: 9999px;
    pointer-events: none;
    opacity: 0.72;
    filter: blur(10px);
}

.app-confirm-dialog::before {
    right: -3.5rem;
    top: -3.5rem;
    height: 9rem;
    width: 9rem;
}

.app-confirm-dialog::after {
    left: -2rem;
    bottom: -3rem;
    height: 7rem;
    width: 7rem;
}

.app-confirm-dialog-danger::before {
    background: radial-gradient(circle, rgba(251, 113, 133, 0.28) 0%, rgba(251, 113, 133, 0) 72%);
}

.app-confirm-dialog-danger::after {
    background: radial-gradient(circle, rgba(244, 63, 94, 0.18) 0%, rgba(244, 63, 94, 0) 72%);
}

.app-confirm-dialog-warning::before {
    background: radial-gradient(circle, rgba(251, 191, 36, 0.28) 0%, rgba(251, 191, 36, 0) 72%);
}

.app-confirm-dialog-warning::after {
    background: radial-gradient(circle, rgba(245, 158, 11, 0.18) 0%, rgba(245, 158, 11, 0) 72%);
}

/* REMOVED CSS: */

/* REMOVED CSS: */

/* REMOVED CSS: */

/* REMOVED CSS: */

/* REMOVED CSS: */

/* REMOVED CSS: */

html[data-theme='dark'] .app-confirm-dialog {
    border-color: rgba(51, 65, 85, 0.95);
    background: linear-gradient(180deg, #0f172a 0%, #111827 100%);
}

html[data-theme='dark'] .app-confirm-dialog-danger::before {
    background: radial-gradient(circle, rgba(251, 113, 133, 0.22) 0%, rgba(251, 113, 133, 0) 72%);
}

html[data-theme='dark'] .app-confirm-dialog-danger::after {
    background: radial-gradient(circle, rgba(190, 24, 93, 0.22) 0%, rgba(190, 24, 93, 0) 72%);
}

html[data-theme='dark'] .app-confirm-dialog-warning::before {
    background: radial-gradient(circle, rgba(251, 191, 36, 0.22) 0%, rgba(251, 191, 36, 0) 72%);
}

html[data-theme='dark'] .app-confirm-dialog-warning::after {
    background: radial-gradient(circle, rgba(245, 158, 11, 0.2) 0%, rgba(245, 158, 11, 0) 72%);
}

html[data-theme='dark'] .app-confirm-title {
    color: #f8fafc;
}

html[data-theme='dark'] .app-confirm-message {
    color: #cbd5e1;
}

html[data-theme='dark'] .app-confirm-icon-danger {
    background: rgba(244, 63, 94, 0.16);
    color: #fda4af;
    box-shadow: inset 0 0 0 1px rgba(251, 113, 133, 0.24);
}

html[data-theme='dark'] .app-confirm-icon-warning {
    background: rgba(245, 158, 11, 0.16);
    color: #fcd34d;
    box-shadow: inset 0 0 0 1px rgba(251, 191, 36, 0.24);
}

html[data-theme='dark'] .surface-empty,
