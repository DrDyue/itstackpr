}

.dash-floor-list,
.dash-room-list {
    @apply space-y-2 border-t border-slate-200 px-3 py-3;
}

.dash-room-item {
    @apply block rounded-2xl border border-slate-200 bg-white px-3 py-3 transition hover:border-sky-200 hover:shadow-sm;
}

