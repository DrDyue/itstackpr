}

.dash-floor-summary {
    @apply flex cursor-pointer list-none items-center justify-between gap-3 px-4 py-4;
}

.dash-floor-summary::-webkit-details-marker {
    display: none;
}

.dash-floor-title {
    @apply text-sm font-semibold text-slate-900;
}

.dash-floor-sub {
    @apply mt-1 text-xs text-slate-500;
}

.dash-floor-badge {
    @apply inline-flex h-9 min-w-9 items-center justify-center rounded-full bg-white px-3 text-sm font-semibold text-slate-700 ring-1 ring-slate-200;
}

.dash-floor-filter {
    @apply mb-3 inline-flex items-center gap-2 rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm font-medium text-slate-700 ring-1 ring-transparent transition hover:border-sky-200 hover:text-sky-700;
}

.dash-floor-filter-active {
    @apply border-sky-200 bg-sky-50 text-sky-800 ring-sky-100;
}

.dash-room-list {
    @apply space-y-2 border-t border-slate-200 pt-3;
}

.dash-room-link {
    @apply block rounded-[1.15rem] border border-slate-200 bg-white px-3 py-3 transition hover:border-sky-200 hover:bg-sky-50/60;
}

.dash-room-link-active {
    @apply border-sky-200 bg-sky-50 shadow-sm;
}

.dash-room-name {
    @apply text-sm font-semibold text-slate-900;
}

.dash-room-meta {
    @apply mt-1 flex flex-wrap gap-x-3 gap-y-1 text-xs text-slate-500;
}

.dash-main-stack {
    @apply space-y-6;
}

.dashboard-pagination {
    @apply flex flex-col gap-3 border-t border-slate-200 px-5 py-4 md:flex-row md:items-center md:justify-between;
}

.dashboard-pagination-meta {
    @apply flex flex-wrap items-center gap-3 text-sm font-medium text-slate-500;
}

.dashboard-pagination-links {
    @apply flex flex-wrap items-center gap-2;
}

.dashboard-pagination-btn {
    @apply inline-flex min-w-10 items-center justify-center rounded-xl border border-slate-200 bg-white px-3 py-2 text-sm font-semibold text-slate-700 transition hover:border-sky-200 hover:bg-sky-50 hover:text-sky-800;
}

.dashboard-pagination-btn-active {
    @apply border-sky-200 bg-sky-50 text-sky-800 shadow-sm;
}

.dashboard-pagination-btn-disabled {
    @apply cursor-default border-slate-200 bg-slate-50 text-slate-400 hover:border-slate-200 hover:bg-slate-50 hover:text-slate-400;
}

